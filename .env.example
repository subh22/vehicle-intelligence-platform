# ── Required ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Claude Model ───────────────────────────────────────────────────────────────
# Use haiku for speed; switch to sonnet for higher accuracy
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Local Model Paths ──────────────────────────────────────────────────────────
VEHICLE_CLASSIFIER_PATH=models/vehicle_classifier.pth
DAMAGE_CLASSIFIER_PATH=models/damage_classifier.pth

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ── Dataset Paths (for training) ───────────────────────────────────────────────
VEHICLE_DATASET_PATH=data/vehicle_classification
DAMAGE_DATASET_PATH=data/car_damage_detection
METADATA_CSV_PATH=data/car_data.csv

# ── Thresholds ─────────────────────────────────────────────────────────────────
VEHICLE_CONFIDENCE_THRESHOLD=0.55
DAMAGE_CONFIDENCE_THRESHOLD=0.45
